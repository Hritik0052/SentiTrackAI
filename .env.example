# ------------------------------------------------------------------
# SentiTrack AI — environment template. Copy to .env and fill in.
# ------------------------------------------------------------------

# App
APP_NAME=SentiTrack AI
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Database
# Local dev (zero config):
DATABASE_URL=sqlite:///./sentitrack.db
# PostgreSQL (production), using psycopg v3 driver:
# DATABASE_URL=postgresql+psycopg://sentitrack:sentitrack@localhost:5432/sentitrack

# JWT
JWT_SECRET_KEY=please-change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenRouter (free models only)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-3-27b-it:free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_TIMEOUT=30
OPENROUTER_MAX_RETRIES=3
